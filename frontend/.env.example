# Frontend environment variables
# Copy this file to .env and fill in your values

# Your Cognito hosted UI domain (no trailing slash)
# Example: https://my-app.auth.us-east-1.amazoncognito.com
VITE_COGNITO_DOMAIN=

# The app client ID from your Cognito User Pool
VITE_COGNITO_CLIENT_ID=

# The redirect URI registered in your Cognito app client
# Must match exactly what you configured in Cognito
VITE_REDIRECT_URI=http://localhost:5173/callback

# URL of your running Flask backend (no trailing slash)
VITE_API_BASE_URL=http://localhost:5000
